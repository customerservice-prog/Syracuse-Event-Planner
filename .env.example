# Resend (https://resend.com) — required for contact form and quote emails
RESEND_API_KEY=
# Inbox that receives leads (your real email)
CONTACT_INBOX_EMAIL=
# Verified sender in Resend, e.g. onboarding@resend.dev or your domain
RESEND_FROM_EMAIL=

# Optional: override public contact info (shown in footer & contact page)
# NEXT_PUBLIC_CONTACT_PHONE=
# NEXT_PUBLIC_CONTACT_PHONE_TEL=
# NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_CONTACT_ADDRESS=
# NEXT_PUBLIC_CONTACT_HOURS=
