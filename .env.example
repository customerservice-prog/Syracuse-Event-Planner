# Canonical URL for SEO (sitemap, Open Graph, JSON-LD). Required in production.
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# Google Search Console HTML tag verification (content value only, optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional — email via Resend. If unset, contact + quote submissions still succeed
# and are written as JSON lines to your server logs (e.g. Railway → deployment → Logs).
# RESEND_API_KEY=
# CONTACT_INBOX_EMAIL=
# RESEND_FROM_EMAIL=

# Optional: public contact info (footer & contact page)
# NEXT_PUBLIC_CONTACT_PHONE=
# NEXT_PUBLIC_CONTACT_PHONE_TEL=
# NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_CONTACT_ADDRESS=
# NEXT_PUBLIC_CONTACT_HOURS=
